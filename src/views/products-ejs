<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <title>Produtos</title>
</head>

<body>

    <div class="container">

        <% listaProdutos.forEach(produto => { %>

            <div class="card">

                <h3>
                    <%= produto.nome %>
                </h3>

                <p>
                    Status:
                    <%= produto.disponivel ? "Em estoque" : "Indisponível" %>
                </p>

            </div>

        <% }) %>

    </div>

</body>

</html>
